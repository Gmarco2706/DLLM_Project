    "# Istogrammi - Distribuzione Good/Bad per Feature Numeriche (4 per riga)\n",
    "# Bar Chart - Distribuzione Good/Bad per Feature Categoriche (4 per riga)\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Caricamento del dataset finale\n",
    "df_final = pd.read_csv('/Users/marcogreco/DLLM_ProjectBiometria/DLLM_Project/data/processed/DatasetFinali/heloc_dataset_cleanedDLLM.csv')\n",
    "\n",
    "print(\"ANALISI - DISTRIBUZIONE GOOD/BAD PER FEATURE\\n\")\n",
    "\n",
    "# Separazione feature e target\n",
    "X = df_final.drop(columns=['RiskPerformance'])\n",
    "y = df_final['RiskPerformance']\n",
    "\n",
    "# Separazione feature numeriche e categoriche\n",
    "numeric_cols = X.select_dtypes(include=['int64', 'float64']).columns.tolist()\n",
    "categorical_cols = X.select_dtypes(include=['object']).columns.tolist()\n",
    "\n",
    "print(f\"Feature numeriche: {len(numeric_cols)}\")\n",
    "print(f\"Feature categoriche: {len(categorical_cols)}\\n\")\n",
    "\n",
    "# ========== PARTE 1: FEATURE NUMERICHE - ISTOGRAMMI ==========\n",
    "if numeric_cols:\n",
    "    print(\"Generazione istogrammi per feature numeriche...\\n\")\n",
    "    \n",
    "    n_features = len(numeric_cols)\n",
    "    n_cols = 4\n",
    "    n_rows = (n_features + n_cols - 1) // n_cols\n",
    "    \n",
    "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(20, 4*n_rows))\n",
    "    axes_flat = axes.flatten()\n",
    "    \n",
    "    for idx, col in enumerate(numeric_cols):\n",
    "        ax = axes_flat[idx]\n",
    "        \n",
    "        # Estrai dati Good e Bad\n",
    "        good_data = X[col][y == 'Good'].dropna()\n",
    "        bad_data = X[col][y == 'Bad'].dropna()\n",
    "        \n",
    "        # Calcola range e bin automaticamente\n",
    "        all_data = pd.concat([good_data, bad_data])\n",
    "        bins = min(30, max(10, len(all_data) // 100))\n",
    "        \n",
    "        # Plot istogrammi overlapposti\n",
    "        ax.hist(good_data, bins=bins, alpha=0.6, label='Good', color='#2ecc71', edgecolor='black', linewidth=0.5)\n",
    "        ax.hist(bad_data, bins=bins, alpha=0.6, label='Bad', color='#e74c3c', edgecolor='black', linewidth=0.5)\n",
    "        \n",
    "        # Configurazione\n",
    "        ax.set_title(f'{col}', fontsize=10, fontweight='bold')\n",
    "        ax.set_xlabel('Valore', fontsize=9)\n",
    "        ax.set_ylabel('Conteggio', fontsize=9)\n",
    "        ax.grid(axis='y', alpha=0.3, linestyle='--')\n",
    "        \n",
    "        if idx == 0:\n",
    "            ax.legend(fontsize=9, loc='upper right')\n",
    "    \n",
    "    # Rimuovi subplot vuoti\n",
    "    for idx in range(n_features, len(axes_flat)):\n",
    "        fig.delaxes(axes_flat[idx])\n",
    "    \n",
    "    plt.suptitle('Istogrammi: Distribuzione Good/Bad - Feature Numeriche', \n",
    "                fontsize=14, fontweight='bold', y=0.995)\n",
    "    plt.tight_layout(rect=[0, 0, 1, 0.98])\n",
    "    plt.savefig('/Users/marcogreco/DLLM_ProjectBiometria/DLLM_Project/data/processed/Plot/istogrammi_numeriche_good_bad.png', \n",
    "               dpi=300, bbox_inches='tight')\n",
    "    plt.show()\n",
    "    \n",
    "    print(\"✓ Istogrammi numeriche salvati: istogrammi_numeriche_good_bad.png\\n\")\n",
    "\n",
    "# ========== PARTE 2: FEATURE CATEGORICHE - BAR CHART ==========\n",
    "if categorical_cols:\n",
    "    print(\"Generazione bar chart per feature categoriche...\\n\")\n",
    "    \n",
