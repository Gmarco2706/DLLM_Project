    "# PCA 3D INTERATTIVO - Grafico Plotly Interattivo\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.decomposition import PCA\n",
    "\n",
    "# Caricamento dataset\n",
    "df = pd.read_csv('/Users/marcogreco/DLLM_ProjectBiometria/DLLM_Project/data/processed/DatasetFinali/heloc_dataset_cleanedDLLM.csv')\n",
    "\n",
    "X = df.drop(columns=['RiskPerformance'])\n",
    "y = df['RiskPerformance']\n",
    "numeric_cols = X.select_dtypes(include=['int64', 'float64']).columns\n",
    "X_numeric = X[numeric_cols]\n",
    "\n",
    "# Standardizzazione\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X_numeric)\n",
    "\n",
    "# PCA - Prime 3 componenti\n",
    "pca = PCA(n_components=3)\n",
    "X_pca = pca.fit_transform(X_scaled)\n",
    "\n",
    "explained_var = pca.explained_variance_ratio_\n",
    "\n",
    "print(\"=\"*80)\n",
    "print(\"GRAFICO 3D INTERATTIVO - PCA Good/Bad\")\n",
    "print(\"=\"*80)\n",
    "print(f\"\\nVarianza spiegata:\")\n",
    "print(f\"  PC1: {explained_var[0]*100:.1f}%\")\n",
    "print(f\"  PC2: {explained_var[1]*100:.1f}%\")\n",
    "print(f\"  PC3: {explained_var[2]*100:.1f}%\\n\")\n",
    "\n",
    "colors = {'Good': '#2ecc71', 'Bad': '#e74c3c'}\n",
    "\n",
    "# Crea figura Plotly 3D\n",
    "fig_3d = go.Figure()\n",
    "\n",
    "# Aggiungi Good\n",
    "mask_good = y == 'Good'\n",
    "fig_3d.add_trace(go.Scatter3d(\n",
    "    x=X_pca[mask_good, 0],\n",
    "    y=X_pca[mask_good, 1],\n",
    "    z=X_pca[mask_good, 2],\n",
    "    mode='markers',\n",
    "    name='Good ✓',\n",
    "    marker=dict(\n",
    "        size=5,\n",
    "        color='#2ecc71',\n",
    "        opacity=0.7,\n",
    "        line=dict(width=1, color='darkgreen')\n",
    "    ),\n",
    "    hovertemplate='<b>GOOD</b><br>PC1: %{x:.2f}<br>PC2: %{y:.2f}<br>PC3: %{z:.2f}<extra></extra>'\n",
    "))\n",
    "\n",
    "# Aggiungi Bad\n",
    "mask_bad = y == 'Bad'\n",
    "fig_3d.add_trace(go.Scatter3d(\n",
    "    x=X_pca[mask_bad, 0],\n",
    "    y=X_pca[mask_bad, 1],\n",
    "    z=X_pca[mask_bad, 2],\n",
    "    mode='markers',\n",
    "    name='Bad ✗',\n",
    "    marker=dict(\n",
    "        size=5,\n",
    "        color='#e74c3c',\n",
    "        opacity=0.7,\n",
    "        line=dict(width=1, color='darkred')\n",
    "    ),\n",
    "    hovertemplate='<b>BAD</b><br>PC1: %{x:.2f}<br>PC2: %{y:.2f}<br>PC3: %{z:.2f}<extra></extra>'\n",
    "))\n",
    "\n",
    "# Aggiungi centroidi\n",
    "good_centroid = X_pca[mask_good].mean(axis=0)\n",
    "bad_centroid = X_pca[mask_bad].mean(axis=0)\n",
    "\n",
    "fig_3d.add_trace(go.Scatter3d(\n",
    "    x=[good_centroid[0]],\n",
    "    y=[good_centroid[1]],\n",
    "    z=[good_centroid[2]],\n",
    "    mode='markers+text',\n",
    "    name='Centro Good',\n",
    "    marker=dict(size=12, color='green', symbol='diamond'),\n",
    "    text=['Centro Good'],\n",
    "    textposition='top center',\n",
    "    hovertemplate='<b>CENTRO GOOD</b><br>PC1: %{x:.2f}<br>PC2: %{y:.2f}<br>PC3: %{z:.2f}<extra></extra>'\n",
    "))\n",
    "\n",
    "fig_3d.add_trace(go.Scatter3d(\n",
    "    x=[bad_centroid[0]],\n",
    "    y=[bad_centroid[1]],\n",
    "    z=[bad_centroid[2]],\n",
    "    mode='markers+text',\n",
    "    name='Centro Bad',\n",
    "    marker=dict(size=12, color='red', symbol='diamond'),\n",
    "    text=['Centro Bad'],\n",
    "    textposition='top center',\n",
    "    hovertemplate='<b>CENTRO BAD</b><br>PC1: %{x:.2f}<br>PC2: %{y:.2f}<br>PC3: %{z:.2f}<extra></extra>'\n",
    "))\n",
    "\n",
    "# Configurazione layout\n",
    "fig_3d.update_layout(\n",
    "    title=dict(\n",
    "        text='<b>PCA 3D INTERATTIVO</b><br><sub>Separabilità classe Good (verde) vs Bad (rosso)</sub>',\n",
    "        font=dict(size=16),\n",
    "        x=0.5,\n",
    "        xanchor='center'\n",
    "    ),\n",
    "    scene=dict(\n",
    "        xaxis=dict(\n",
    "            title=f'<b>PC1</b> ({explained_var[0]*100:.1f}%)',\n",
    "            backgroundcolor='rgba(240,240,240,1)',\n",
    "            gridcolor='white',\n",
    "            showbackground=True\n",
    "        ),\n",
    "        yaxis=dict(\n",
    "            title=f'<b>PC2</b> ({explained_var[1]*100:.1f}%)',\n",
    "            backgroundcolor='rgba(240,240,240,1)',\n",
    "            gridcolor='white',\n",
    "            showbackground=True\n",
    "        ),\n",
    "        zaxis=dict(\n",
    "            title=f'<b>PC3</b> ({explained_var[2]*100:.1f}%)',\n",
    "            backgroundcolor='rgba(240,240,240,1)',\n",
    "            gridcolor='white',\n",
    "            showbackground=True\n",
    "        ),\n",
    "        camera=dict(eye=dict(x=1.5, y=1.5, z=1.3))\n",
    "    ),\n",
    "    width=1000,\n",
    "    height=800,\n",
    "    hovermode='closest',\n",
    "    legend=dict(\n",
    "        x=0.02,\n",
    "        y=0.98,\n",
    "        bgcolor='rgba(255,255,255,0.9)',\n",
    "        bordercolor='black',\n",
    "        borderwidth=2,\n",
    "        font=dict(size=11)\n",
    "    ),\n",
    "    font=dict(size=12),\n",
    "    showlegend=True\n",
    ")\n",
    "\n",
    "fig_3d.write_html('/Users/marcogreco/DLLM_ProjectBiometria/DLLM_Project/data/processed/Plot/pca_3d_interactive.html')\n",
    "fig_3d.show()\n",
    "\n",
    "print(\"✓ File salvato: pca_3d_interactive.html\")\n",
    "\n",
    "# Statistiche di separabilità\n",
    "print(f\"\\nSTATISTICHE:\")\n",
    "distance = np.linalg.norm(good_centroid - bad_centroid)\n",
    "print(f\"  Centro Good: ({good_centroid[0]:.2f}, {good_centroid[1]:.2f}, {good_centroid[2]:.2f})\")\n",
    "print(f\"  Centro Bad:  ({bad_centroid[0]:.2f}, {bad_centroid[1]:.2f}, {bad_centroid[2]:.2f})\")\n",
    "print(f\"  Distanza tra centroidi: {distance:.3f}\")\n",
    "\n",
    "if distance > 1.5:\n",
    "    print(f\"\\n✓ BUONA SEPARABILITÀ - le classi sono ben distinguibili!\")\n",
    "elif distance > 0.8:\n",
    "    print(f\"\\n~ MEDIA SEPARABILITÀ - qualche sovrapposizione\")\n",
    "else:\n",
    "    print(f\"\\n✗ SCARSA SEPARABILITÀ - classi molto sovrapposte\")\n",
    "print(\"=\"*80)"
   ]
  },
